# 环境变量：对所有 zsh 实例生效，设置 PATH、编辑器、语言等基础环境
# 每次启动 Zsh 进程时，都会加载（读取并执行）此文件，无论是登录shell、交互式 shell，还是非交互式 shell（例如运行脚本时）。
# 由于其通用性，`.zshenv` 只应包含环境变量定义。

# Homebrew
# 原始写法：调用 Homebrew 官方 `brew shellenv` 输出并执行环境变量配置。
# macOS 下 `brew shellenv` 还会间接调用 `/usr/libexec/path_helper` 计算 PATH/MANPATH。
# 这套写法语义最完整，但每次 zsh 启动都会 fork 外部命令；冷启动时会增加新终端卡顿。
# 如果将来出现 Homebrew 路径、MANPATH 或 shellenv 行为兼容问题，可以恢复下面这一整块原始写法。
#
# macOS Homebrew 原始写法：
# if [ -x "/opt/homebrew/bin/brew" ]; then
#   eval "$(/opt/homebrew/bin/brew shellenv)"
# fi
#
# Linux Homebrew 原始写法：
# if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
#   eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
# fi

# Homebrew 当前写法：静态设置标准安装路径下的环境变量，避免每次启动 zsh 都 fork `brew shellenv` 和 `path_helper`。
# macOS Homebrew
if [ -x "/opt/homebrew/bin/brew" ]; then
  export HOMEBREW_PREFIX="/opt/homebrew"
  export HOMEBREW_CELLAR="/opt/homebrew/Cellar"
  export HOMEBREW_REPOSITORY="/opt/homebrew"
  case ":$PATH:" in
    *":/opt/homebrew/bin:/opt/homebrew/sbin:"*) ;;
    *) export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH" ;;
  esac
  export MANPATH="/opt/homebrew/share/man${MANPATH+:$MANPATH}:"
  export INFOPATH="/opt/homebrew/share/info:${INFOPATH:-}"
fi

# Linux Homebrew
if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]; then
  export HOMEBREW_PREFIX="/home/linuxbrew/.linuxbrew"
  export HOMEBREW_CELLAR="/home/linuxbrew/.linuxbrew/Cellar"
  export HOMEBREW_REPOSITORY="/home/linuxbrew/.linuxbrew/Homebrew"
  case ":$PATH:" in
    *":/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:"*) ;;
    *) export PATH="/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:$PATH" ;;
  esac
  export MANPATH="/home/linuxbrew/.linuxbrew/share/man${MANPATH+:$MANPATH}:"
  export INFOPATH="/home/linuxbrew/.linuxbrew/share/info:${INFOPATH:-}"
fi

# XDG Base Directory Specification
# 让 macOS 上的工具（如 lazygit）使用 ~/.config 而不是 ~/Library/Application Support
export XDG_CONFIG_HOME="$HOME/.config"

# 设置系统语言环境为美式英语, 字符编码为 UTF-8
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# 设置终端颜色(修复远程登录主机时 kcbt 异常导致的命令预测字符无法清除的问题)
export TERM=xterm-256color

# default editor
# 决定使用 vim 作为默认的编辑器
# - nvim 太重了，而且编辑命令时，没有自动折行，导致长命令编辑体验很烂(虽然通过配置应该能自动折行，但我不想再碰 nvim 了)
# - micro VS Code/Cursor 的终端中 ctrl q 可能已经被占用，而且 micro 编辑命令不方便
export VISUAL='vim'   # 首选，大多数程序用这个
export EDITOR='vim'   # 后备，少数老程序只认这个

# $HOME/.local/bin 添加到 PATH
# 存放用户自己安装的、不属于系统级的可执行文件
# 例如当你编写了一些自己使用的脚本（例如 Python、Bash 脚本）或从源代码编译了一些程序时，可以将它们的可执行文件放在 $HOME/.local/bin 目录 # 中。这样，你可以方便地在终端中直接使用这些脚本或程序，而无需输入它们的完整路径。
export PATH="$HOME/.local/bin:$PATH"

# Rust/Cargo
. "$HOME/.cargo/env"
